# === Agent API keys ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
EXA_API_KEY=

# === BrowseComp judge (OpenAI-compatible chat-completions) ===
# Any chat model the grader can use for answer extraction. The judge client
# accepts a base_url override and reads its API key from whichever env var you
# name here — so you can point it at OpenRouter, Together, a local vLLM, etc.
BROWSECOMP_JUDGE_MODEL=gpt-4o-mini
# BROWSECOMP_JUDGE_BASE_URL=https://openrouter.ai/api/v1
# BROWSECOMP_JUDGE_API_KEY_ENV=OPENROUTER_API_KEY

# === DeepSearchQA grader (Gemini 2.5 Flash, pinned by the authors) ===
# Used by bench/deepsearchqa.py as the autorater. Get a key at
# https://aistudio.google.com/apikey.
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_TOKEN=
GEMINI_MODEL=gemini-2.5-flash

# === Optional: HuggingFace token for gated Qwen3 weights ===
HF_TOKEN=
